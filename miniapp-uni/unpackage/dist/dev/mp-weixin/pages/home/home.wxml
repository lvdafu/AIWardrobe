<view class="page data-v-92bb8f34"><view class="card data-v-92bb8f34"><view class="section-title data-v-92bb8f34">当前城市</view><input class="input data-v-92bb8f34" placeholder="输入城市，如上海" data-event-opts="{{[['input',[['__set_model',['','location','$event',[]]]]]]}}" value="{{location}}" bindinput="__e"/><button type="primary" data-event-opts="{{[['tap',[['loadWeather',['$event']]]]]}}" bindtap="__e" class="data-v-92bb8f34">刷新天气</button></view><block wx:if="{{weather}}"><view class="card data-v-92bb8f34"><view class="section-title data-v-92bb8f34">天气信息</view><view class="line data-v-92bb8f34">{{"地点："+(weather.location||location)}}</view><view class="line data-v-92bb8f34">{{"天气："+weather.condition}}</view><view class="line data-v-92bb8f34">{{"温度："+weather.temperature+"°C"}}</view><view class="line data-v-92bb8f34">{{"体感："+weather.feelsLike+"°C"}}</view></view></block><view class="card data-v-92bb8f34"><view class="section-title data-v-92bb8f34">快捷入口</view><button data-event-opts="{{[['tap',[['goRecommend',['$event']]]]]}}" bindtap="__e" class="data-v-92bb8f34">今日推荐</button><button data-event-opts="{{[['tap',[['goWardrobe',['$event']]]]]}}" bindtap="__e" class="data-v-92bb8f34">我的衣橱</button><button data-event-opts="{{[['tap',[['goUpload',['$event']]]]]}}" bindtap="__e" class="data-v-92bb8f34">上传衣物</button></view></view>